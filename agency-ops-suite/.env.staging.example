# Environment Variables - STAGING
# Copy this to Vercel dashboard → Settings → Environment Variables
# DO NOT commit actual values to git

# Supabase (Staging Project)
NEXT_PUBLIC_SUPABASE_URL=https://[staging-project-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[staging-anon-key-here]
SUPABASE_SERVICE_ROLE_KEY=[staging-service-role-key-here]

# Application Configuration
NEXT_PUBLIC_USE_SEED_DATA=false
ADMIN_EMAIL_ALLOWLIST=your-staging-email@example.com

# Stripe (Test Mode)
STRIPE_SECRET_KEY=sk_test_[your-staging-test-key]
STRIPE_PUBLISHABLE_KEY=pk_test_[your-staging-test-key]
STRIPE_WEBHOOK_SECRET=whsec_test_[your-staging-webhook-secret]

# Resend (Email - Staging)
RESEND_API_KEY=re_[your-staging-resend-key]

# Webhooks & Security
INTAKE_WEBHOOK_SECRET=staging-intake-secret-12345
DEV_AUTH_BYPASS=false

# Optional: Sentry for error tracking (add after Phase 3)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# NEXT_PUBLIC_ENVIRONMENT=staging
