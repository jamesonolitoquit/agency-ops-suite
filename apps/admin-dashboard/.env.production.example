# Example production env for admin-dashboard
# Copy values into Vercel dashboard or a secure vault (do NOT commit secrets)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: use the newer publishable key instead of anon when available.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

SUPABASE_SECRET_KEY=
# Legacy fallback if your project still uses JWT-based service roles.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_USE_SEED_DATA=false
DEV_AUTH_BYPASS=false
ADMIN_EMAIL_ALLOWLIST=

INTAKE_WEBHOOK_SECRET=
INTAKE_RATE_LIMIT_WINDOW_MS=60000
INTAKE_RATE_LIMIT_MAX_REQUESTS=100
INTAKE_IDEMPOTENCY_TTL_MS=600000

DEBUG=false
NEXT_PUBLIC_ANALYTICS_DISABLED=true

# Optional integrations (populate as needed)
# SENTRY_AUTH_TOKEN=
# SENDGRID_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
