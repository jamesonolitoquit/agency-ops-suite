NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_USE_SEED_DATA=true
ADMIN_EMAIL_ALLOWLIST=owner@agency.com,ops@agency.com
ADMIN_ROLE_ALLOWLIST=owner@agency.com:admin,ops@agency.com:operator
DEV_AUTH_BYPASS=false
DEV_AUTH_BYPASS_EMAIL=dev-bypass@local.test
INTAKE_WEBHOOK_SECRET=replace-with-strong-random-secret
INTAKE_RATE_LIMIT_WINDOW_MS=60000
INTAKE_RATE_LIMIT_MAX_REQUESTS=30
INTAKE_IDEMPOTENCY_TTL_MS=600000